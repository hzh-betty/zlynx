{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 18,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug (Clang + Ninja)",
      "description": "开发调试预设：使用 clang++ 和 Ninja，默认构建 unit/integration 测试。",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release (Clang + Ninja)",
      "description": "发布构建预设：关闭测试，只构建库目标。",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF"
      }
    },
    {
      "name": "coverage",
      "displayName": "Coverage (Clang + Ninja)",
      "description": "覆盖率预设：Debug + BUILD_TESTING + ZLYNX_ENABLE_COVERAGE。",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/coverage",
      "cacheVariables": {
        "ZLYNX_ENABLE_COVERAGE": "ON"
      }
    },
    {
      "name": "perf",
      "displayName": "Performance binaries (RelWithDebInfo, Clang + Ninja)",
      "description": "性能测试预设：使用 RelWithDebInfo，保留优化和调试符号，stress/perf 二进制不注册进 CTest。",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/perf",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "ZLYNX_BUILD_PERF_TESTS": "ON",
        "ZLYNX_BUILD_STRESS_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "coverage",
      "configurePreset": "coverage"
    },
    {
      "name": "perf",
      "configurePreset": "perf"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "coverage",
      "configurePreset": "coverage",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
